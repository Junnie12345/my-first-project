theme_classic() + #白底
theme(
aspect.ratio = 1.2, # (選用) 在預覽視窗強制鎖定 1.5倍高
axis.text = element_text(size = 12, color = "black"),
axis.title = element_text(size = 14, face = "bold"),
plot.title = element_text(hjust = 0.5, size = 18, face = "bold"), #hjust0.5中間0.5左邊1右邊
plot.subtitle = element_text(hjust = 0.5),
#axis.ticks.x = element_blank(), #unit設0就等於這個
axis.text.x = element_text( size = 12,
color = "black",
#face = "italic",
angle =  45,
hjust = 1,
margin = margin(t=5)),
axis.ticks.length.x = unit(0.2, "cm"), #要調整tick，字要分開調整
axis.ticks.length.y = unit(-0.1, "cm"), #要調整tick，字要分開調整
#axis.text.y = element_text(margin = margin(r = 1)) #t=top,r=right
#panel.background = element_rect(fill = "lightsteelblue",colour = "lightsteelblue",size = 0.5,linetype = "solid"),
#panel.grid.major = element_line(colour = "white",size = 0.5,linetype = "solid"),
#panel.grid.minor = element_line(colour = "white",size = 0.25,linetype = "dashed")
)
print(p)
