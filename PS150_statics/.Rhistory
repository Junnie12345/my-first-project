#------------------------------
#error plot（Point-Range Plot）----
# 模擬資料
df_simple <- data.frame(
Group = c("A", "B", "C"),
Mean = c(10, 15, 8),
SD = c(1, 1.5, 0.8)
)
my_manual_colors <- c(
"A" = "#edf8b1",
"B" = "#7fcdbb",
"C" = "#2c7fb8"
)
# 繪圖物件
p <- ggplot(df_simple, aes(x = Group, y = Mean, color = Group)) +
labs(
title = "point-range plot",
subtitle = "practive",
y = "(%)",
x = "type"
)+
# 1. 誤差棒 (寫在前面)
geom_errorbar(
aes(ymin = Mean - SD, ymax = Mean + SD),
width = 0.2,      # 誤差棒寬度調窄一點更精緻
linewidth = 0.8,
color = "black"   # 誤差棒維持黑色
) +
# 2. 中心點 (取代 Bar，寫在後面會蓋在線上面)
geom_point(
size = 3,         # 點的大小
shape = 16,       # 21 號是有外框的圓圈
#fill = "white",   # 圓心填白色
#stroke = 1      # 圓圈邊框粗細
) +
#指定顏色
scale_color_manual(values = my_manual_colors) +
# 3. 座標軸設定
scale_x_discrete(expand = expansion(add = 1)) +
scale_y_continuous(limits = c(0, 20), expand = expansion(mult = c(0, 0.1))) +
# 4. 主題與格線
theme_classic() +
theme(
aspect.ratio = 1.2,
axis.title.x = element_text(size = 14,face = "bold"),
axis.title.y =  element_text(size = 14,face = "bold"),
plot.title = element_text(hjust = 0.5,size = 18, face ="bold"),
plot.subtitle = element_text(hjust = 0.5),
panel.grid.major.y = element_line(color = "gray85"),
panel.grid.major.x = element_line(color = "gray85", linetype = "dashed"),
legend.position = "none", # 點的顏色與 X 軸重複，可以隱藏圖例
axis.text.x = element_text(size = 12, color = "black"),
axis.text.y = element_text(size = 12, color = "black",margin = margin(r =2))
)
print(p)
#----自動調整scale------------
library(ggplot2)
library(scales) # 務必載入，這有助於自動化刻度
# --- 動態運算區 ---
y_low  <- min(df_simple$Mean - df_simple$SD)
y_high <- max(df_simple$Mean + df_simple$SD)
y_span <- y_high - y_low
# 設定動態 limits (上下各留 15% 空間，達成自動 Zoom 效果)
y_lims <- c(y_low - 0.15 * y_span, y_high + 0.15 * y_span)
# --- 關鍵修改：動態量尺 ---
# --- 1. 動態運算漂亮且符合數量的刻度 ---
# 找出數據範圍
data_range <- c(min(df_simple$Mean - df_simple$SD), max(df_simple$Mean + df_simple$SD))
# 第一次嘗試：n 設為 4，通常會得到 4-5 個刻度
my_breaks <- pretty(data_range, n = 4)
# 如果不幸超過 5 個，就強制縮減
if(length(my_breaks) > 5) {
my_breaks <- pretty(data_range, n = 3)
}
# 設定同步的 Y 軸範圍 (讓刻度剛好頂到天花板與地板)
final_y_lims <- range(my_breaks)
# --- 2. 繪圖物件 ---
p <- ggplot(df_simple, aes(x = Group, y = Mean, color = Group)) +
labs(
title = "dynamics Ticks Plot",
subtitle = paste("Actual Ticks:", length(my_breaks)),
y = "(%)", x = "Type"
) +
geom_errorbar(aes(ymin = Mean - SD, ymax = Mean + SD),
width = 0.2, linewidth = 0.8, color = "black") +
geom_point(size = 4, shape = 16) +
scale_color_manual(values = my_manual_colors) +
# --- 3. 套用算好的刻度與範圍 ---
scale_y_continuous(
limits = final_y_lims,
breaks = my_breaks,
#labels = scales::label_number(accuracy = 0.1)
) +
theme_classic() +
theme(
aspect.ratio = 1.2,
axis.title = element_text(size = 14, face = "bold"),
plot.title = element_text(hjust = 0.5, size = 18, face ="bold"),
panel.grid.major.y = element_line(color = "gray85"),
panel.grid.major.x = element_line(color = "gray85", linetype = "dashed"),
legend.position = "none",
axis.text = element_text(size = 12, color = "black")
)
print(p)
#色盤檢視--------------
library(scales)
show_col(viridis_pal(option = "viridis")(10)) # 顯示 viridis 的 10 個顏色
show_col(viridis_pal(option = "plasma")(10))  # 顯示 plasma 的 10 個顏色
#---多組多時間
library(ggplot2)
library(scales)
set.seed(40)
df_grouped <- data.frame(
Day = factor(rep(1:7, each = 2)),
Group = rep(c("A", "B"), times = 7),
Mean = c(5, 6, 8, 9, 12, 11, 15, 13, 18, 16, 22, 19, 25, 23),
SD = runif(14, 1, 2)
)
my_pair_colors <- c("A" = "#0571b0", "B" = "#fdb863")
# 1. 找出所有數據中誤差棒的極值
data_range <- c(
min(df_grouped$Mean - df_grouped$SD),
max(df_grouped$Mean + df_grouped$SD)
)
# 2. 計算漂亮刻度 (n=4 預期得到 4~5 個)
my_breaks <- pretty(data_range, n = 4)
# 3. 如果太擠 (>5個)，就重新算一次
if(length(my_breaks) > 5) {
my_breaks <- pretty(data_range, n = 3)
}
# 4. 鎖定 Y 軸最終顯示範圍
final_y_lims <- range(my_breaks)
p_bar <- ggplot(df_grouped, aes(x = Day, y = Mean, fill = Group)) +
# 幾何圖層
geom_col(
width = 0.7,
position = position_dodge(width = 0.7),
color = "black"
) +
# 幾何圖層：誤差棒 (必須也用同樣的 dodge 寬度才能對齊柱子中心)
geom_errorbar(
aes(ymin = Mean - SD, ymax = Mean + SD),
width = 0.2,
position = position_dodge(width = 0.7),
color = "black"
) +
# 顏色與量尺
scale_fill_manual(values = my_pair_colors) +
scale_y_continuous(
limits = final_y_lims,
breaks = my_breaks,
expand = c(0, 0)
) +
scale_x_discrete(
expand = expansion(add = c(1, 1))
)+
# 標籤設定
labs(
title = "7-Day Grouped Analysis",
subtitle = paste("Actual Y-ticks:", length(my_breaks)),
x = "Observation Day",
y = "Score Value"
) +
# 主題風格
theme_classic() +
theme(
aspect.ratio = 0.6, # 七天的圖比較長，比例設 0.6 比較舒展
plot.title = element_text(size = 18, face = "bold", hjust = 0.5),
axis.title = element_text(size = 14, face = "bold"),
axis.text = element_text(size = 12, color = "black"),
legend.position = "right" # 圖例放上面，方便閱讀 A/B
)
print(p_bar)
#---point plot=====
# 1. 定義對應關係
my_pair_colors <- c("A" = "#0571b0", "B" = "#fdb863")
my_pair_shape  <- c("A" = 16, "B" = 17)
# --- 繪圖物件 ---
p_line <- ggplot(df_grouped, aes(x = Day, y = Mean, color = Group, shape = Group, group = Group)) +
# 1. 幾何圖層：連線 (放在最底層)
geom_line(
position = position_dodge(width = 0.5), # 位移必須與點一致
linewidth = 1,
alpha = 0.7
) +
# 2. 幾何圖層：誤差棒
geom_errorbar(
aes(ymin = Mean - SD, ymax = Mean + SD),
width = 0.2,
position = position_dodge(width = 0.5), # 位移必須與點一致
color = "black",
alpha = 0.8
) +
# 3. 幾何圖層：中心點 (放在最頂層蓋住線)
geom_point(
size = 4,
position = position_dodge(width = 0.5),
alpha = 0.9
) +
# 設定顏色與形狀
scale_color_manual(values = my_pair_colors) +
scale_shape_manual(values = my_pair_shape) +
# 座標軸設定
scale_y_continuous(
limits = final_y_lims,
breaks = my_breaks,
expand = expansion(mult = c(0, 0.1))
) +
scale_x_discrete(expand = expansion(add = c(0.8, 0.8))) +
labs(
title = "7-Day Growth Trend",
subtitle = "Group A vs Group B",
x = "Observation Day",
y = "Score (%)"
) +
theme_classic() +
theme(
aspect.ratio = 0.6,
plot.title = element_text(hjust = 0.5, face = "bold", size = 18),
legend.position = "top"
)
print(p_line)
library(ggplot2)
library(scales)
set.seed(42)
df_dispersed <- data.frame(
Day = factor(rep(1:7, each = 2)),
Group = rep(c("A", "B"), times = 7),
# 數據有上升趨勢
Mean = c(10, 12, 15, 18, 20, 25, 30, 28, 35, 40, 45, 42, 50, 55),
# SD 設定得特別大 (離散度高)
SD = runif(14, 8, 15)
)
my_pair_colors <- c("A" = "#0571b0", "B" = "#fdb863")
my_pair_shape  <- c("A" = 16, "B" = 17)
# 1. 找出最長的 Error Bar (長度 = 2 * SD)
max_error_len <- max(2 * df_dispersed$SD)
# 2. 計算目標 Y 軸總長度 (強制跨距為最大誤差棒的 10 倍)
target_span <- max_error_len / 0.10
# 3. 找出目前數據的真實極值與中點
y_min_data <- min(df_dispersed$Mean - df_dispersed$SD)
y_max_data <- max(df_dispersed$Mean + df_dispersed$SD)
mid_y <- (y_max_data + y_min_data) / 2
# 4. 以數據中點為核心，上下展開 target_span
y_low_zoom <- mid_y - (target_span / 2)
y_high_zoom <- mid_y + (target_span / 2)
# 如果你希望 Y 軸不要掉到負數，可以強制下限為 0：
if(y_low_zoom < 0) y_low_zoom <- 0
# 5. 算出漂亮刻度與最終邊界
my_breaks <- pretty(c(y_low_zoom, y_high_zoom), n = 4)
if(length(my_breaks) > 5) my_breaks <- pretty(c(y_low_zoom, y_high_zoom), n = 3)
final_y_lims <- range(my_breaks)
# --- 計算 Day 7 的標註高度 ---
# 找出 Day 7 最高的 Error Bar 頂點
day7_max <- max(df_dispersed$Mean[df_dispersed$Day == 7] + df_dispersed$SD[df_dispersed$Day == 7])
# 設定橫線與星星的 Y 軸高度 (加上總跨距的 3% 和 6% 作為留白)
y_span <- final_y_lims[2] - final_y_lims[1]
line_y <- day7_max + (y_span * 0.03)
star_y <- day7_max + (y_span * 0.05)
# --- 開始繪圖 ---
p_final <- ggplot(df_dispersed, aes(x = Day, y = Mean, color = Group, shape = Group, group = Group)) +
# 1. 數據圖層 (連線、誤差棒、點)
geom_line(position = position_dodge(width = 0.5), linewidth = 1, alpha = 0.7) +
geom_errorbar(aes(ymin = Mean - SD, ymax = Mean + SD),
width = 0.2, position = position_dodge(width = 0.5), color = "black") +
geom_point(size = 4, position = position_dodge(width = 0.5)) +
# 2. 【新增】顯著性標註 (Day 7)
# 畫橫線 (從 A 的 x 座標畫到 B 的 x 座標)
annotate("segment", x = 7 - 0.25, xend = 7 + 0.25, y = line_y, yend = line_y,
color = "black", linewidth = 0.8) +
# 畫星星 (放在中間)
annotate("text", x = 7, y = star_y, label = "*", size = 8, fontface = "bold") +
# 3. 顏色、形狀與量尺
scale_color_manual(values = my_pair_colors) +
scale_shape_manual(values = my_pair_shape) +
scale_y_continuous(limits = final_y_lims, breaks = my_breaks, expand = c(0, 0)) +
scale_x_discrete(expand = expansion(add = c(0.8, 0.8))) +
# 4. 標籤與主題
labs(
title = "7-Day Trend (Highly Dispersed Data)",
subtitle = "Y-axis scaled to keep Error Bars <= 10%",
x = "Observation Day", y = "Score"
) +
theme_classic() +
theme(
aspect.ratio = 0.6,
plot.title = element_text(size = 18, face = "bold", hjust = 0.5),
axis.title = element_text(size = 14, face = "bold"),
axis.text = element_text(size = 12, color = "black"),
legend.position = "top"
)
print(p_final)
library(ggplot2)
library(scales)
library(ggsignif) # 載入神級標註套件
# --- 1. 資料與基礎設定 ---
set.seed(42)
df_dispersed <- data.frame(
Day = factor(rep(1:7, each = 2)),
Group = rep(c("A", "B"), times = 7),
Mean = c(10, 12, 15, 18, 20, 25, 30, 28, 35, 40, 45, 42, 50, 55),
SD = runif(14, 8, 15)
)
my_pair_colors <- c("A" = "#0571b0", "B" = "#fdb863")
my_pair_shape  <- c("A" = 16, "B" = 17)
# --- 2. 解決裁切與動態刻度運算 ---
# 找出所有數據真實的最底與最高點
true_y_min <- min(df_dispersed$Mean - df_dispersed$SD)
true_y_max <- max(df_dispersed$Mean + df_dispersed$SD)
# 計算漂亮刻度 (注意：這裡不再強制把負數變成 0，讓它誠實顯示)
my_breaks <- pretty(c(true_y_min, true_y_max), n = 5)
final_y_lims <- range(my_breaks)
# 找出 Day 7 最高的點，用來決定星星要放多高
day7_max <- max(df_dispersed$Mean[df_dispersed$Day == 7] + df_dispersed$SD[df_dispersed$Day == 7])
star_height <- day7_max + 5 # 括號浮在最高點上方 5 個單位處
# --- 3. 繪圖物件 ---
p_final <- ggplot(df_dispersed, aes(x = Day, y = Mean, color = Group, shape = Group, group = Group)) +
# 數據圖層
geom_line(position = position_dodge(width = 0.5), linewidth = 1, alpha = 0.7) +
geom_errorbar(aes(ymin = Mean - SD, ymax = Mean + SD),
width = 0.2, position = position_dodge(width = 0.5), color = "black") +
geom_point(size = 4, position = position_dodge(width = 0.5)) +
# --- 【關鍵新增】使用 ggsignif ---
geom_signif(
y_position = star_height, # 括號高度
xmin = 7 - 0.25,          # 括號左腳 (Day 7 的 A 組)
xmax = 7 + 0.25,          # 括號右腳 (Day 7 的 B 組)
annotation = "**",        # 標註內容 (例如兩顆星)
tip_length = 0.02,        # 括號往下折的長度比例
textsize = 6,             # 星星的大小
color = "black",          # 括號與星星的顏色
vjust = 0.5               # 調整星星與括號的上下間距
) +
# 顏色與形狀
scale_color_manual(values = my_pair_colors) +
scale_shape_manual(values = my_pair_shape) +
# --- 【關鍵修正】防止裁切的 Y 軸設定 ---
scale_y_continuous(
limits = final_y_lims,
breaks = my_breaks,
# 底部稍微給一點點空間(0.02)，防止最底部的線貼在 X 軸上被吃掉
expand = expansion(mult = c(0.02, 0.1))
) +
scale_x_discrete(expand = expansion(add = c(0.8, 0.8))) +
labs(
title = "7-Day Trend (Corrected Error Bars)",
subtitle = "Using ggsignif for Annotations",
x = "Observation Day", y = "Score"
) +
theme_classic() +
theme(
aspect.ratio = 0.6,
plot.title = element_text(size = 18, face = "bold", hjust = 0.5),
axis.title = element_text(size = 14, face = "bold"),
axis.text = element_text(size = 12, color = "black"),
legend.position = "top"
)
print(p_final)
library(ggplot2)
library(scales)
library(ggsignif)
# --- 1. 資料準備 (同樣的高離散資料) ---
set.seed(42)
df_dispersed <- data.frame(
Day = factor(rep(1:7, each = 2)),
Group = rep(c("A", "B"), times = 7),
Mean = c(10, 12, 15, 18, 20, 25, 30, 28, 35, 40, 45, 42, 50, 55),
SD = runif(14, 8, 15)
)
my_pair_colors <- c("A" = "#0571b0", "B" = "#fdb863")
my_pair_shape  <- c("A" = 16, "B" = 17)
# --- 2. 【終極運算】：10% 法則 + 防裁切 ---
# A. 找出數據的真實邊界與中點
true_y_min <- min(df_dispersed$Mean - df_dispersed$SD)
true_y_max <- max(df_dispersed$Mean + df_dispersed$SD)
mid_y <- (true_y_max + true_y_min) / 2
# B. 計算 10% 法則所需的「目標總跨距」
max_error_len <- max(2 * df_dispersed$SD)
target_span <- max_error_len / 0.10
# C. 把目標跨距「套」在數據中點上，往上下展開
y_low_zoom <- mid_y - (target_span / 2)
y_high_zoom <- mid_y + (target_span / 2)
# D. 算出漂亮刻度 (這會讓畫布比 target_span 再稍微大一點點，確保誤差棒 $\le 10\%$)
my_breaks <- pretty(c(y_low_zoom, y_high_zoom), n = 5)
final_y_lims <- range(my_breaks)
# --- 3. 計算 Day 7 的星星高度 ---
day7_max <- max(df_dispersed$Mean[df_dispersed$Day == 7] + df_dispersed$SD[df_dispersed$Day == 7])
# 高度設定為：最高點 + 總畫布跨距的 3% (這樣比例永遠完美)
star_height <- day7_max + (final_y_lims[2] - final_y_lims[1]) * 0.03
# --- 4. 繪圖物件 ---
p_final <- ggplot(df_dispersed, aes(x = Day, y = Mean, color = Group, shape = Group, group = Group)) +
geom_line(position = position_dodge(width = 0.5), linewidth = 1, alpha = 0.7) +
geom_errorbar(aes(ymin = Mean - SD, ymax = Mean + SD),
width = 0.2, position = position_dodge(width = 0.5), color = "black") +
geom_point(size = 4, position = position_dodge(width = 0.5)) +
# 手動標註 (依賴你外部算好的 GEE 結果)
geom_signif(
y_position = star_height,
xmin = 7 - 0.25, xmax = 7 + 0.25,
annotation = "***", # 放上你 GEE 算出來的顯著性
tip_length = 0.02, textsize = 6, color = "black", vjust = 0.5
) +
scale_color_manual(values = my_pair_colors) +
scale_shape_manual(values = my_pair_shape) +
# Y 軸套用我們算好的終極邊界 (expand 設為 0，因為範圍已經算得很精準了)
scale_y_continuous(limits = final_y_lims, breaks = my_breaks, expand = c(0, 0)) +
scale_x_discrete(expand = expansion(add = c(0.8, 0.8))) +
labs(
title = "7-Day Trend (GEE Adjusted)",
subtitle = "Error bars strictly <= 10% of Y-axis with no clipping",
x = "Observation Day", y = "Estimated Marginal Means"
) +
theme_classic() +
theme(
aspect.ratio = 0.6,
plot.title = element_text(size = 18, face = "bold", hjust = 0.5),
axis.title = element_text(size = 14, face = "bold"),
axis.text = element_text(size = 12, color = "black"),
legend.position = "top"
)
print(p_final)
# --- 1. 資料準備 (同樣的高離散資料) ---
set.seed(42)
df_dispersed <- data.frame(
Day = factor(rep(1:7, each = 2)),
Group = rep(c("A", "B"), times = 7),
Mean = c(10, 12, 15, 18, 20, 25, 30, 28, 35, 40, 45, 42, 50, 55),
SD = runif(14, 8, 15)
)
my_pair_colors <- c("A" = "#0571b0", "B" = "#fdb863")
my_pair_shape  <- c("A" = 16, "B" = 17)
# --- 2. 【終極運算】：10% 法則 + 防裁切 ---
# A. 找出數據的真實邊界與中點
true_y_min <- min(df_dispersed$Mean - df_dispersed$SD)
true_y_max <- max(df_dispersed$Mean + df_dispersed$SD)
mid_y <- (true_y_max + true_y_min) / 2
# B. 計算 10% 法則所需的「目標總跨距」
max_error_len <- max(2 * df_dispersed$SD)
target_span <- max_error_len / 0.15
# C. 把目標跨距「套」在數據中點上，往上下展開
y_low_zoom <- mid_y - (target_span / 2)
y_high_zoom <- mid_y + (target_span / 2)
# D. 算出漂亮刻度 (這會讓畫布比 target_span 再稍微大一點點，確保誤差棒 $\le 10\%$)
my_breaks <- pretty(c(y_low_zoom, y_high_zoom), n = 5)
final_y_lims <- range(my_breaks)
# --- 3. 計算 Day 7 的星星高度 ---
day7_max <- max(df_dispersed$Mean[df_dispersed$Day == 7] + df_dispersed$SD[df_dispersed$Day == 7])
# 高度設定為：最高點 + 總畫布跨距的 3% (這樣比例永遠完美)
star_height <- day7_max + (final_y_lims[2] - final_y_lims[1]) * 0.03
# --- 4. 繪圖物件 ---
p_final <- ggplot(df_dispersed, aes(x = Day, y = Mean, color = Group, shape = Group, group = Group)) +
geom_line(position = position_dodge(width = 0.5), linewidth = 1, alpha = 0.7) +
geom_errorbar(aes(ymin = Mean - SD, ymax = Mean + SD),
width = 0.2, position = position_dodge(width = 0.5), color = "black") +
geom_point(size = 4, position = position_dodge(width = 0.5)) +
# 手動標註 (依賴你外部算好的 GEE 結果)
geom_signif(
y_position = star_height,
xmin = 7 - 0.25, xmax = 7 + 0.25,
annotation = "***", # 放上你 GEE 算出來的顯著性
tip_length = 0.02, textsize = 6, color = "black", vjust = 0.5
) +
scale_color_manual(values = my_pair_colors) +
scale_shape_manual(values = my_pair_shape) +
# Y 軸套用我們算好的終極邊界 (expand 設為 0，因為範圍已經算得很精準了)
scale_y_continuous(limits = final_y_lims, breaks = my_breaks, expand = c(0, 0)) +
scale_x_discrete(expand = expansion(add = c(0.8, 0.8))) +
labs(
title = "7-Day Trend (GEE Adjusted)",
subtitle = "Error bars strictly <= 10% of Y-axis with no clipping",
x = "Observation Day", y = "Estimated Marginal Means"
) +
theme_classic() +
theme(
aspect.ratio = 0.6,
plot.title = element_text(size = 18, face = "bold", hjust = 0.5),
axis.title = element_text(size = 14, face = "bold"),
axis.text = element_text(size = 12, color = "black"),
legend.position = "top"
)
print(p_final)
